{
	"$schema": "https://json.schemastore.org/tsconfig.json",
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"rootDir": ".",
		"noEmit": true,
		"emitDeclarationOnly": false,
		"composite": false,
		"noImplicitAny": false,
		"types": [ "style-imports" ]
	},
	"include": [ "**/*.ts", "**/*.tsx" ],
	"exclude": [ "**/test/**", "build", "node_modules" ]
}
