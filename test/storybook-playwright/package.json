{
	"name": "@wordpress/storybook-playwright",
	"version": "0.0.0",
	"description": "Storybook Playwright tests for WordPress Gutenberg components.",
	"private": true,
	"author": "The WordPress Contributors",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"wordpress",
		"gutenberg",
		"storybook",
		"playwright"
	],
	"homepage": "https://github.com/WordPress/gutenberg/tree/HEAD/test/storybook-playwright/README.md",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/WordPress/gutenberg.git",
		"directory": "test/storybook-playwright"
	},
	"bugs": {
		"url": "https://github.com/WordPress/gutenberg/issues"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"@storybook/react-vite": "^10.1.11",
		"@wordpress/element": "file:../../packages/element",
		"@wordpress/storybook": "file:../../storybook",
		"storybook": "^10.1.11"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"storybook:build": "storybook build -c ./storybook -o ./build",
		"storybook:dev": "storybook dev -c ./storybook -p 50241",
		"test:e2e": "playwright test --config playwright.config.ts"
	}
}
