{
	"$schema": "https://json.schemastore.org/tsconfig.json",
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"types": [
			"gutenberg-env",
			"gutenberg-test-env",
			"jest",
			"style-imports"
		]
	},
	"references": [
		{ "path": "../components" },
		{ "path": "../compose" },
		{ "path": "../data" },
		{ "path": "../date" },
		{ "path": "../deprecated" },
		{ "path": "../dom" },
		{ "path": "../element" },
		{ "path": "../i18n" },
		{ "path": "../icons" },
		{ "path": "../keycodes" },
		{ "path": "../primitives" },
		{ "path": "../private-apis" },
		{ "path": "../theme" },
		{ "path": "../ui" },
		{ "path": "../url" },
		{ "path": "../warning" }
	],
	"files": [ "global.d.ts" ],
	"exclude": [
		"src/**/*.android.js",
		"src/**/*.ios.js",
		"src/**/*.native.js",
		"src/**/react-native-*",
		"src/**/stories/**/*.jsx", // only exclude js files, tsx files should be checked
		"src/**/test/**/*.js" // only exclude js files, ts{x} files should be checked
	]
}
