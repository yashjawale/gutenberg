{
	"$schema": "https://json.schemastore.org/tsconfig.json",
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"target": "es2020",
		"module": "commonjs",
		"lib": [ "es2020" ],
		"outDir": "./build",
		"rootDir": "src",
		"types": [ "node" ],
		"checkJs": false,
		"emitDeclarationOnly": false
	},
	"include": [ "src" ],
	"exclude": [ "**/*.test.*", "**/test/**" ]
}
