{
	"$schema": "https://json.schemastore.org/tsconfig.json",
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"target": "es2020",
		"module": "commonjs",
		"lib": [ "es2020" ],
		"outDir": "./build",
		"rootDir": "./lib",
		"types": [ "node" ],
		"checkJs": false,
		"emitDeclarationOnly": false,
		"composite": false,
		"declaration": false,
		"declarationMap": false,
		"declarationDir": null
	},
	"include": [ "lib/**/*" ],
	"exclude": [ "**/*.test.*", "**/test/**" ]
}
