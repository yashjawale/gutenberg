	"license": "GPL-2.0-or-later",
	"keywords": [
		"wordpress",
		"gutenberg",
		"content-types",
		"post-types",
		"taxonomies"
	],
	"homepage": "https://github.com/WordPress/gutenberg/tree/HEAD/packages/content-types/README.md",
	"repository": {
